{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "moduleDetection": "force",
    "outDir": "dist",
    "types": ["node"],
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src", "vite.config.ts"]
}
