{
  "name": "example",
  "version": "1.0.0",
  "scripts": {
    "main": "npm run typical && rm -rf dist && tsc --project tsconfig.json && node dist/src/main.js",
    "lint": "npm run typical && vp check",
    "format": "vp fmt && typical format types.t",
    "typical": "typical generate types.t --typescript-dir generated"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "6.0.3",
    "vite-plus": "0.2.3"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.3"
  }
}
